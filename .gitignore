*.pem
*.key
*.crt
.env
.env.local
secrets/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.pyc
__pycache__/

# Docker
.dockerignore

# AWS
.aws/

# Backup files
*.bak
*.backup
