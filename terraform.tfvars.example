# ============================================
# Example Terraform Variables Configuration
# Copy this file to terraform.tfvars and fill in your values
# ============================================

# General Configuration
project_name = "litellm"
environment  = "production"
aws_region   = "us-east-1"

# Enable/Disable deletion protection for production
enable_deletion_protection = true

# IP whitelist for ALB access (use ["0.0.0.0/0"] to allow all)
# Example: ["1.2.3.4/32", "10.0.0.0/8"]
allowed_cidrs = ["0.0.0.0/0"]

# ============================================
# ECS Configuration
# ============================================

ecs_desired_count = 2
ecs_min_capacity  = 2
ecs_max_capacity  = 10

# Task resources (4 vCPU, 8GB RAM)
ecs_task_cpu    = 4096
ecs_task_memory = 8192

# Enable ECS Exec for debugging (disable in production)
enable_ecs_exec = false

# ============================================
# Auto Scaling Configuration
# ============================================

# Target utilization percentages
cpu_target_value    = 70
memory_target_value = 75

# Request count per target
alb_request_count_target = 1000

# Scheduled scaling (optional)
enable_scheduled_scaling = false
scheduled_scale_up_min   = 4
scheduled_scale_up_max   = 10
scheduled_scale_down_min = 2
scheduled_scale_down_max = 4

# ============================================
# RDS Database Configuration
# ============================================

db_instance_class       = "db.t3.medium"
db_engine_version       = "17.9"
db_allocated_storage    = 100
db_max_allocated_storage = 500

db_name     = "litellm"
db_username = "litellm_admin"

# High availability
db_multi_az = true

# Backup configuration
db_backup_retention_period = 7

# Safety settings
skip_final_snapshot = false
db_apply_immediately = false

# ============================================
# Domain and SSL Configuration
# ============================================

# Set to true to enable HTTPS with custom domain
enable_https = false

# Your domain configuration (required if enable_https = true)
# domain_name        = "example.com"
# litellm_subdomain  = "litellm.example.com"

# Optional: Additional domains
# certificate_sans = ["api.example.com", "*.example.com"]

# Optional features
enable_ipv6        = false
enable_health_check = false

# ============================================
# LiteLLM Configuration
# ============================================

# IMPORTANT: Generate secure keys before deploying!
# Run these commands to generate:
#   Master Key: echo "sk-$(openssl rand -hex 16)"
#   Salt Key:   openssl rand -hex 32

litellm_master_key = "sk-CHANGE-ME-GENERATE-YOUR-OWN-KEY"
litellm_salt_key   = "CHANGE-ME-RUN-openssl-rand-hex-32-TO-GENERATE"

litellm_log_level = "INFO"

# Disable detailed debug in production
enable_detailed_debug = false

# ============================================
# API Keys Configuration
# ============================================

# Add your LLM provider API keys here
# These will be stored securely in AWS Secrets Manager

openai_api_key    = ""  # sk-...
anthropic_api_key = ""  # sk-ant-...
azure_api_key     = ""  # Your Azure key
gemini_api_key    = ""  # Your Gemini key

# AWS Bedrock access via IAM Role
# No credentials needed! LiteLLM will automatically use the ECS Task IAM Role
# This is more secure than using access keys

# ============================================
# Monitoring and Alerting
# ============================================

# SNS topic ARN for CloudWatch alarms (optional)
# Create an SNS topic and subscribe your email first
# alarm_sns_topic_arn = "arn:aws:sns:us-east-1:123456789012:litellm-alerts"

alarm_sns_topic_arn = ""

# CloudWatch logs retention
cloudwatch_log_retention_days = 7

# ============================================
# CloudFront Configuration (Optional)
# ============================================

# Enable CloudFront CDN for global acceleration
# Recommended for: Asia, Europe, and other regions far from ALB
enable_cloudfront = false

# CloudFront price class
# - PriceClass_All: All edge locations (best performance, highest cost)
# - PriceClass_200: US, Europe, Asia, Middle East, Africa (recommended)
# - PriceClass_100: US and Europe only (lowest cost)
cloudfront_price_class = "PriceClass_All"

# ============================================
# Option 1: CloudFront with Default Domain
# ============================================
#
# If you just want CloudFront acceleration without custom domain:
# 1. Set enable_cloudfront = true
# 2. Leave cloudfront_custom_domain = ""
# 3. Access via: https://d111111abcdef8.cloudfront.net
#
# No Route53 or additional certificate needed!

# ============================================
# Option 2: CloudFront with Custom Domain
# ============================================
#
# If you want a custom domain for CloudFront:
# 1. Set enable_cloudfront = true
# 2. Set enable_https = true
# 3. Set domain_name (your root domain)
# 4. Set cloudfront_custom_domain (your CloudFront subdomain)
# 5. CloudFront certificate will be created in us-east-1 automatically
#
# Example:
# enable_cloudfront       = true
# enable_https            = true
# domain_name             = "example.com"
# cloudfront_custom_domain = "api.example.com"
#
# Access via: https://api.example.com

cloudfront_custom_domain = ""

# CloudFront logging (optional)
# Create an S3 bucket first for CloudFront logs
# cloudfront_logging_bucket = "my-cloudfront-logs-bucket"
cloudfront_logging_bucket = ""

# ============================================
# AWS WAF Configuration (Optional)
# ============================================

# Enable WAF for DDoS protection and rate limiting
enable_waf = false

# Rate limit (requests per 5 minutes per IP)
waf_rate_limit = 2000

# Geo restriction (optional)
# - "none": No restrictions (default)
# - "whitelist": Only allow specified countries
# - "blacklist": Block specified countries
cloudfront_geo_restriction_type = "none"

# Country codes for geo restriction (ISO 3166-1 alpha-2)
# Example: ["US", "CN", "JP", "SG", "KR"]
cloudfront_geo_restriction_locations = []

# Cache TTL settings (for API, keep at 0 to disable caching)
cloudfront_min_ttl     = 0
cloudfront_default_ttl = 0
cloudfront_max_ttl     = 0

# ============================================
# Additional Tags
# ============================================

additional_tags = {
  Project     = "LiteLLM"
  CostCenter  = "Engineering"
  Terraform   = "true"
}
